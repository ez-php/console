{
  "name": "ez-php/console",
  "version": "0.1.0",
  "description": "Lightweight console infrastructure for PHP — command dispatcher, argument parser, and colored output helpers",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andreas Uretschnig",
      "email": "andreas.uretschnig@gmail.com"
    }
  ],
  "keywords": ["console", "cli", "command", "terminal", "php"],
  "homepage": "https://github.com/ez-php/console",
  "support": {
    "issues": "https://github.com/ez-php/console/issues",
    "source": "https://github.com/ez-php/console"
  },
  "require": {
    "php": "^8.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "EzPhp\\Console\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "analyse": "phpstan analyse",
    "test": "phpunit",
    "full": "composer analyse && composer cs && composer test"
  }
}
